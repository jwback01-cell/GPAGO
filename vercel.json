{
  "cleanUrls": true,
  "trailingSlash": false,
  "regions": ["icn1"],
  "crons": [
    { "path": "/api/track-ranks", "schedule": "0 1 * * *" }
  ],
  "functions": {
    "api/track-ranks.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
